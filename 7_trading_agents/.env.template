# Trading Agents System Configuration
# Copy this file to .env and fill in your actual credentials

# OpenClaw Configuration
OPENCLAW_WS_URL=ws://127.0.0.1:18792
OPENCLAW_AUTH_TOKEN=your_openclaw_token_here

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo

# Reddit Configuration (for sentiment analysis)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Interactive Brokers Configuration
IB_HOST=127.0.0.1
IB_PORT=7497  # Live trading port (7496 for paper trading)
IB_CLIENT_ID=1
IB_ACCOUNT=your_ib_account_number

# Paths
DB_PATH=./data/trading.db
REPORTS_DIR=./reports
DATA_DIR=./data

# Scheduling
TIMEZONE=US/Eastern

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/trading_agents.log

# Trading Parameters (optional - uses defaults from config.py if not set)
MIN_CONFIDENCE_THRESHOLD=0.70
